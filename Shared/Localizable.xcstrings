    "Do you want to save the location of where you found your device? (This makes it easier for you to find your devices next time)" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Möchtest du den Ort speichern, an dem du dein Gerät gefunden hast? (Das erleichtert dir das Wiederfinden deiner Geräte)" } },
