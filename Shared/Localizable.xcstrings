        "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Verificação rápida de permissões" } }
      }
    },
    "Scan" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Scannen" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Scan" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Escanear" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Scanner" } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Scansiona" } },
        "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Escanear" } }
      }
    },
    "That panicked feeling when your earbuds vanish? PodRadar ends it in seconds." : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Diese Panik, wenn deine Kopfhörer verschwunden sind? PodRadar beendet sie in Sekunden." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "That panicked feeling when your earbuds vanish? PodRadar ends it in seconds." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "¿Ese momento de pánico cuando desaparecen tus auriculares? PodRadar lo termina en segundos." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Cette panique quand tes écouteurs disparaissent ? PodRadar y met fin en quelques secondes." } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Quel senso di panico quando le tue cuffie spariscono? PodRadar lo risolve in pochi secondi." } },
        "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Aquele pânico quando seu fone desaparece? O PodRadar resolve em segundos." } }
      }
    },
    "Walk toward it and watch the signal strength rise" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Geh darauf zu und beobachte, wie die Signalstärke steigt" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Walk toward it and watch the signal strength rise" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Camina hacia él y observa cómo aumenta la señal" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Avance vers lui et regarde le signal augmenter" } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Avvicinati e osserva il segnale aumentare" } },
        "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Caminhe em direção a ele e veja o sinal aumentar" } }
      }
    },
    "Open Settings" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Einstellungen öffnen" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Open Settings" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Abrir ajustes" } },
