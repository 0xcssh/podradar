        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Dernière position" } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Ultima posizione" } },
        "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Última localização" } }
      }
    },
    "Location access is off, so PodRadar can't remember where a device was last detected." : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Der Standortzugriff ist deaktiviert, daher kann sich PodRadar nicht merken, wo ein Gerät zuletzt erkannt wurde." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Location access is off, so PodRadar can't remember where a device was last detected." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "El acceso a la ubicación está desactivado, así que PodRadar no puede recordar dónde se detectó un dispositivo por última vez." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "L'accès à la localisation est désactivé, donc PodRadar ne peut pas mémoriser où un appareil a été détecté pour la dernière fois." } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "L'accesso alla posizione è disattivato, quindi PodRadar non può ricordare dove è stato rilevato per l'ultima volta un dispositivo." } },
        "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "O acesso à localização está desativado, então o PodRadar não consegue lembrar onde um dispositivo foi detectado pela última vez." } }
      }
    },
    "Make sure the device is within Bluetooth signal range" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Stelle sicher, dass sich das Gerät in Bluetooth-Reichweite befindet" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Make sure the device is within Bluetooth signal range" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Asegúrate de que el dispositivo esté dentro del alcance de la señal Bluetooth" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Vérifie que l'appareil est à portée du signal Bluetooth" } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Assicurati che il dispositivo sia entro il raggio del segnale Bluetooth" } },
        "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Verifique se o dispositivo está dentro do alcance do sinal Bluetooth" } }
      }
    },
    "Make sure your headphones are powered on and nearby." : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Stelle sicher, dass dein Kopfhörer eingeschaltet und in der Nähe ist." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Make sure your headphones are powered on and nearby." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Asegúrate de que tus auriculares estén encendidos y cerca." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Vérifie que ton casque est allumé et à proximité." } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Assicurati che le tue cuffie siano accese e nelle vicinanze." } },
        "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Verifique se seu fone está ligado e por perto." } }
