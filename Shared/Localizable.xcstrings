        "it" : { "stringUnit" : { "state" : "translated", "value" : "Apri impostazioni" } },
        "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Abrir ajustes" } }
      }
    },
    "Pinpoint Your Device's\nExact Location" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Finde den genauen\nStandort deines Geräts" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Pinpoint Your Device's\nExact Location" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Localiza la ubicación\nexacta de tu dispositivo" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Localise précisément\nton appareil" } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Individua la posizione\nesatta del tuo dispositivo" } },
        "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Localize a posição\nexata do seu dispositivo" } }
      }
    },
    "PodRadar can remember where a device was last detected." : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "PodRadar kann sich merken, wo ein Gerät zuletzt erkannt wurde." } },
