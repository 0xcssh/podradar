    "If you are looking for AirPods, make sure the AirPods are not in a case" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Wenn du AirPods suchst, stelle sicher, dass sie sich nicht im Etui befinden" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "If you are looking for AirPods, make sure the AirPods are not in a case" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Si buscas tus AirPods, asegúrate de que no estén dentro del estuche" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Si tu cherches des AirPods, vérifie qu'ils ne sont pas dans leur boîtier" } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Se stai cercando degli AirPods, assicurati che non siano nella custodia" } },
