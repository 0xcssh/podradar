    "Tap \"Found it!\" on a device to save its location here." : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Tippe bei einem Gerät auf „Gefunden!“, um seinen Standort hier zu speichern." } },
