        "it" : { "stringUnit" : { "state" : "translated", "value" : "PodRadar Pro" } },
        "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "PodRadar Pro" } }
      }
    },
    "PodRadar needs Bluetooth access. Enable it in Settings." : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "PodRadar benötigt Bluetooth-Zugriff. Aktiviere ihn in den Einstellungen." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "PodRadar needs Bluetooth access. Enable it in Settings." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "PodRadar necesita acceso a Bluetooth. Actívalo en Ajustes." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "PodRadar a besoin d'accéder au Bluetooth. Active-le dans les réglages." } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "PodRadar necessita dell'accesso al Bluetooth. Attivalo nelle Impostazioni." } },
        "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "O PodRadar precisa de acesso ao Bluetooth. Ative-o nos Ajustes." } }
      }
    },
    "PodRadar remembers where a device was last seen once it goes out of range." : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "PodRadar merkt sich, wo ein Gerät zuletzt gesehen wurde, sobald es außer Reichweite gerät." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "PodRadar remembers where a device was last seen once it goes out of range." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "PodRadar recuerda dónde se vio un dispositivo por última vez en cuanto sale de alcance." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "PodRadar mémorise l'endroit où un appareil a été vu pour la dernière fois dès qu'il sort de portée." } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "PodRadar ricorda dove è stato visto per l'ultima volta un dispositivo non appena esce dal raggio d'azione." } },
        "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "O PodRadar lembra onde um dispositivo foi visto pela última vez assim que ele sai de alcance." } }
      }
    },
    "PodRadar remembers where a device was last seen once you tap \"Found it!\" or it goes out of range." : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "PodRadar merkt sich, wo ein Gerät zuletzt gesehen wurde, sobald du auf „Gefunden!“ tippst oder es außer Reichweite gerät." } },
