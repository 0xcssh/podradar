        "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Ainda sem localizações anteriores" } }
      }
    },
    "PodRadar finds every Bluetooth device around you" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "PodRadar findet jedes Bluetooth-Gerät in deiner Nähe" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "PodRadar finds every Bluetooth device around you" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "PodRadar encuentra todos los dispositivos Bluetooth a tu alrededor" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "PodRadar trouve tous les appareils Bluetooth autour de toi" } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "PodRadar trova ogni dispositivo Bluetooth intorno a te" } },
        "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "O PodRadar encontra todos os dispositivos Bluetooth ao seu redor" } }
      }
    },
    "Quick Permission Check" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Kurze Berechtigungsprüfung" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Quick Permission Check" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Verificación rápida de permisos" } },
