    "PodRadar can remember where a device was last detected." : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "PodRadar kann sich merken, wo ein Gerät zuletzt erkannt wurde." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "PodRadar can remember where a device was last detected." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "PodRadar puede recordar dónde se detectó un dispositivo por última vez." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "PodRadar peut mémoriser l'endroit où un appareil a été détecté pour la dernière fois." } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "PodRadar può ricordare dove è stato rilevato per l'ultima volta un dispositivo." } },
        "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "O PodRadar pode lembrar onde um dispositivo foi detectado pela última vez." } }
      }
    },
    "PodRadar Pro" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "PodRadar Pro" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "PodRadar Pro" } },
