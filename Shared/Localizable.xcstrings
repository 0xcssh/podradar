    },
    "No previous locations yet" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Noch keine früheren Standorte" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "No previous locations yet" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Aún no hay ubicaciones anteriores" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Aucune position enregistrée pour l'instant" } },
