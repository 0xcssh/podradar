    "Location access is off, so PodRadar can't remember where a device was last detected." : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Der Standortzugriff ist deaktiviert, daher kann sich PodRadar nicht merken, wo ein Gerät zuletzt erkannt wurde." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Location access is off, so PodRadar can't remember where a device was last detected." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "El acceso a la ubicación está desactivado, así que PodRadar no puede recordar dónde se detectó un dispositivo por última vez." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "L'accès à la localisation est désactivé, donc PodRadar ne peut pas mémoriser où un appareil a été détecté pour la dernière fois." } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "L'accesso alla posizione è disattivato, quindi PodRadar non può ricordare dove è stato rilevato per l'ultima volta un dispositivo." } },
        "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "O acesso à localização está desativado, então o PodRadar não consegue lembrar onde um dispositivo foi detectado pela última vez." } }
      }
    },
    "Make sure the device is within Bluetooth signal range" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Stelle sicher, dass sich das Gerät in Bluetooth-Reichweite befindet" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Make sure the device is within Bluetooth signal range" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Asegúrate de que el dispositivo esté dentro del alcance de la señal Bluetooth" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Vérifie que l'appareil est à portée du signal Bluetooth" } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Assicurati che il dispositivo sia entro il raggio del segnale Bluetooth" } },
        "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Verifique se o dispositivo está dentro do alcance do sinal Bluetooth" } }
      }
    },
    "Make sure your headphones are powered on and nearby." : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Stelle sicher, dass dein Kopfhörer eingeschaltet und in der Nähe ist." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Make sure your headphones are powered on and nearby." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Asegúrate de que tus auriculares estén encendidos y cerca." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Vérifie que ton casque est allumé et à proximité." } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Assicurati che le tue cuffie siano accese e nelle vicinanze." } },
        "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Verifique se seu fone está ligado e por perto." } }
      }
    },
    "Map" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Karte" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Map" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Mapa" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Carte" } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Mappa" } },
        "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Mapa" } }
      }
    },
    "Map Location" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Kartenposition" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Map Location" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Ubicación en el mapa" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Position sur la carte" } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Posizione sulla mappa" } },
        "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Localização no mapa" } }
      }
    },
    "Move around and follow the signal strength to find your device" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Bewege dich und folge der Signalstärke, um dein Gerät zu finden" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Move around and follow the signal strength to find your device" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Muévete y sigue la intensidad de la señal para encontrar tu dispositivo" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Déplace-toi et suis la force du signal pour retrouver ton appareil" } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Spostati e segui l'intensità del segnale per trovare il tuo dispositivo" } },
        "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Mova-se e siga a intensidade do sinal para encontrar seu dispositivo" } }
      }
    },
    "Never Lose Your\nAirPods Again" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Verliere nie wieder\ndeine AirPods" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Never Lose Your\nAirPods Again" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "No vuelvas a perder\ntus AirPods" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Ne perds plus jamais\ntes AirPods" } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Non perdere mai più\ni tuoi AirPods" } },
        "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Nunca mais perca\nseus AirPods" } }
      }
    },
    "Next, we'll ask for Bluetooth and Location access — needed to scan for your devices and remember where you found them. Nothing is ever shared." : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Als Nächstes bitten wir um Bluetooth- und Standortzugriff — nötig, um deine Geräte zu scannen und dir zu merken, wo du sie gefunden hast. Es wird nie etwas geteilt." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Next, we'll ask for Bluetooth and Location access — needed to scan for your devices and remember where you found them. Nothing is ever shared." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "A continuación, pediremos acceso a Bluetooth y ubicación — necesario para buscar tus dispositivos y recordar dónde los encontraste. Nunca compartimos nada." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "On va te demander l'accès au Bluetooth et à la localisation — nécessaire pour scanner tes appareils et mémoriser où tu les as trouvés. Rien n'est jamais partagé." } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Ora ti chiederemo l'accesso a Bluetooth e posizione — necessario per scansionare i tuoi dispositivi e ricordare dove li hai trovati. Non condividiamo mai nulla." } },
        "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Em seguida, pediremos acesso ao Bluetooth e à localização — necessário para escanear seus dispositivos e lembrar onde você os encontrou. Nada é compartilhado." } }
      }
    },
    "NEAR" : {
      "comment" : "Short badge label — keep very short in translation to fit the pill.",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "NAH" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "NEAR" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "CERCA" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "PROCHE" } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "VICINO" } },
        "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "PERTO" } }
      }
    },
    "No locations yet" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Noch keine Standorte" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "No locations yet" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Aún no hay ubicaciones" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Aucune position pour l'instant" } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Ancora nessuna posizione" } },
